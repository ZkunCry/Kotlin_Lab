<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Знак операции -->
    <TextView
        android:id="@+id/tvOperationSign"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="24sp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@+id/etOperand1"
        app:layout_constraintTop_toTopOf="@+id/etOperand1"
        app:layout_constraintBottom_toBottomOf="@+id/etOperand2" />

    <EditText
        android:id="@+id/etOperand1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Операнд 1"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginStart="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etOperand2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Операнд 2"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/etOperand1"
        app:layout_constraintStart_toStartOf="@+id/etOperand1"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопки операций (Исправленный LinearLayout) -->
    <LinearLayout
        android:id="@+id/idButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/etOperand2"
        app:layout_constraintStart_toStartOf="@+id/etOperand2"
        app:layout_constraintEnd_toEndOf="parent">


        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="+"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btnSub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="-"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btnMul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="*"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btnDiv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="/"
            android:layout_weight="1"/>
    </LinearLayout>

    <!-- Знак равенства -->
    <TextView
        android:id="@+id/tvEqualsSign"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="24sp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@+id/tvResult"
        app:layout_constraintTop_toTopOf="@+id/tvResult"
        app:layout_constraintBottom_toBottomOf="@+id/tvResult" />

    <!-- Поле результата -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Результат"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/idButtons"
        app:layout_constraintStart_toStartOf="@+id/idButtons"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnClose"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Закрыть"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@+id/tvResult"
        app:layout_constraintStart_toStartOf="@+id/tvResult"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>